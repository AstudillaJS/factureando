# ============================================================================
# FACTUREANDO - Configuración de Variables de Entorno
# ============================================================================

# Gemini API Configuration
# Obtén tu clave en: https://ai.google.dev
GEMINI_API_KEY=your_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATA_DIR=./data

# AFIP/ARCA Configuration (Autoridad de Recaudación de Recursos Aduaneros)
# Configuración necesaria para integración con AFIP
AFIP_CUIT=
AFIP_CRT_PATH=
AFIP_KEY_PATH=

# Mercado Pago Configuration
# Token de acceso para integración con Mercado Pago
MERCADOPAGO_TOKEN=

# Google Cloud Configuration (if using Google Cloud services)
GOOGLE_CLOUD_PROJECT=
