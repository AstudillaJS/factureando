{
  "name": "factureando",
  "private": true,
  "version": "2.0.2",
  "description": "Sistema de Facturación Automática para Monotributistas",
  "main": "electron-main.cjs",
  "author": "AstudillaJS",
  "scripts": {
    "dev": "concurrently \"tsx server.ts\" \"vite\" \"wait-on http://localhost:3010 && electron .\"",
    "build": "node backup-dist.cjs && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "package": "npm run build && electron-builder build --windows",
    "release": "npm run build && electron-builder build --windows --publish always",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "start": "node dist/server.cjs",
    "publish": "node publish.cjs",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.factureando.app",
    "productName": "Factureando",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AstudillaJS",
        "repo": "factureando",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/lynx-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Factureando"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json",
      "data/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@arcasdk/core": "^2.0.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "node-forge": "^1.4.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/node-forge": "^1.3.14",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "fs-extra": "^11.3.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  }
}
